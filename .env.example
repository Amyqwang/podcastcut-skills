# === ASR 语音转录 ===
# 在 config.yaml 中设置 asr.provider 选择服务商

# 阿里云 DashScope FunASR（默认）
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# 腾讯云 ASR（可选，config.yaml 中 asr.provider 设为 tencent 时使用）
# 获取地址：https://console.cloud.tencent.com/cam/capi
# TENCENT_SECRET_ID=your-secret-id
# TENCENT_SECRET_KEY=your-secret-key

# === 质检（可选）===
# Gemini API Key（质检 Layer 2 AI 听感评估）
# 获取地址：https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# === 云存储（可选，config.yaml 中 upload.strategy 为 oss/cos 时使用）===

# 阿里云 OSS
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
# OSS_BUCKET_NAME=your-bucket-name

# 腾讯云 COS（复用上面的 TENCENT_SECRET_ID/KEY）
# TENCENT_COS_REGION=ap-shanghai
# TENCENT_COS_BUCKET=your-bucket-name

# === 用户（可选）===
# 指定当前用户（默认 default）
# PODCASTCUT_USER=default
